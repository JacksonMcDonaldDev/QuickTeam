<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/reset.css">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/htmx.min.js" defer></script>
    <title><%= list.name %> · QuickTeam</title>
</head>
<body data-owner="<%= isOwner %>">
    <header>
        <h1><%= list.name %></h1>
    </header>

    <main>
        <% if (!member) { %>
            <!-- Name-gate: a device joins once by typing a name. No account, no password. -->
            <section id="join" class="join">
                <% if (collision) { %>
                    <h2>Someone here is already called <%= collision.name %></h2>
                    <p>Are you them?</p>
                    <form method="post" action="/l/<%= list.token %>/join">
                        <input type="hidden" name="name" value="<%= collision.name %>">
                        <input type="hidden" name="choice" value="existing">
                        <button type="submit">Yes, continue as <%= collision.name %></button>
                    </form>
                    <form method="post" action="/l/<%= list.token %>/join">
                        <label>No, I'll use a different name
                            <input type="text" name="name" autofocus required>
                        </label>
                        <button type="submit">Join</button>
                    </form>
                <% } else { %>
                    <h2>Join this list</h2>
                    <form method="post" action="/l/<%= list.token %>/join">
                        <label>Your name
                            <input type="text" name="name" autofocus required>
                        </label>
                        <button type="submit">Join</button>
                    </form>
                    <% if (error) { %>
                        <p class="error"><%= error %></p>
                    <% } %>
                <% } %>
            </section>
        <% } else { %>
            <section class="items-region">
                <!-- The add-input lives outside #items so live polling (slice 5) can
                     swap the items region without clobbering what's being typed. -->
                <form class="add-item"
                      method="post" action="/l/<%= list.token %>/items"
                      hx-post="/l/<%= list.token %>/items"
                      hx-target="#items" hx-swap="innerHTML"
                      hx-on::after-request="this.reset()">
                    <input class="text" type="text" name="text"
                           placeholder="Add an item" autocomplete="off" required>
                    <button type="submit" class="submit">Add</button>
                </form>

                <div id="items" class="items">
                    <%- include('partials/items', { list, member }) %>
                </div>
            </section>
        <% } %>
    </main>
</body>
</html>
